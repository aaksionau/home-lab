# Copy to terraform.tfvars and fill in your actual values.

server_host           = "192.168.1.50"   # the Ubuntu server's current LAN IP
server_user            = "ubuntu"
ssh_private_key_path   = "~/.ssh/id_ed25519"
ssh_public_key          = "ssh-ed25519 AAAA... you@yourmachine"

# VMs attach to a real Linux bridge (br0) so the host can reach them too —
# see README for the netplan setup. Only set this if you named it something
# other than "br0".
# libvirt_bridge_name = "br0"

lan_subnet_cidr = "192.168.1.0/24"
lan_gateway     = "192.168.1.1"
lan_dns_servers = ["1.1.1.1", "8.8.8.8"]

control_plane_ip = "192.168.1.60"          # pick free static IPs outside your router's DHCP range
worker_ip        = "192.168.1.61"

# github.com/settings/tokens?type=beta -> fine-grained token scoped to just
# aaksionau/weather-home-station, "Administration" repo permission: read/write.
github_runner_pat = "github_pat_..."
